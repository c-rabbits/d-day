# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Server-only: used for soft-delete (bypasses RLS). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth (카카오/구글): Supabase Dashboard > Authentication > URL Configuration
# - Redirect URLs에 프로덕션/로컬 콜백 URL 추가 (예: https://your-domain/auth/callback, http://localhost:3000/auth/callback)
# - Authentication > Providers에서 Kakao/Google 활성화 후 각 개발자 콘솔에서 발급한 Client ID·Secret 입력
# - 구글 로그인 상세 설정: docs/GOOGLE_LOGIN_SETUP.md 참고
